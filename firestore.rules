rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure custom helper validator
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$');
    }

    // Users collection rules
    match /users/{email} {
      allow get, write: if isValidId(email);
      allow list: if true; // Allowed for system-stats and backend seeding
    }

    // Payments collection rules
    match /payments/{paymentId} {
      allow get, write: if isValidId(paymentId);
      allow list: if true; // Allowed for payment registration and admin lists
    }
  }
}
