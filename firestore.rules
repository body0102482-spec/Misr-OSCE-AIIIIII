rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure custom helper validators
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+@?[a-zA-Z0-9_\\-\\.]*$');
    }

    // Users collection rules
    match /users/{email} {
      allow get, write: if isValidId(email);
      allow list: if false; // Reject client-side scraping
    }

    // Payments collection rules
    match /payments/{paymentId} {
      allow read, write: if isValidId(paymentId);
    }
  }
}
